page {
  background: #0b0a08;
  color: #f6efe6;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.app-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(214, 176, 116, 0.12), transparent 34%),
    linear-gradient(180deg, #0b0a08 0%, #11100d 58%, #0e0c09 100%);
}

.safe-top {
  height: env(safe-area-inset-top);
}

.page-body {
  padding: 32rpx 28rpx 160rpx;
}

.hero-card,
.surface-card,
.work-card,
.stat-card,
.action-card,
.list-card,
.step-card,
.profile-card {
  background: rgba(20, 17, 14, 0.94);
  border: 1rpx solid rgba(214, 176, 116, 0.16);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.18);
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f6efe6;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #b8b1a7;
  font-size: 24rpx;
  line-height: 1.6;
}

.section {
  margin-top: 36rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-link {
  font-size: 24rpx;
  color: #d6b074;
}

.gold-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding: 0 28rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e3c186, #c3944f);
  color: #1b1611;
  font-size: 28rpx;
  font-weight: 700;
}

.secondary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding: 0 28rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(214, 176, 116, 0.08);
  border: 1rpx solid rgba(214, 176, 116, 0.32);
  color: #f6efe6;
  font-size: 28rpx;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(214, 176, 116, 0.1);
  color: #d6b074;
  font-size: 20rpx;
}

.tag-dark {
  background: rgba(246, 239, 230, 0.08);
  color: #f6efe6;
}

.muted {
  color: #b8b1a7;
}

.accent {
  color: #d6b074;
}

.rise {
  color: #e2604d;
}

.success {
  color: #6ea67a;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.grid-three {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tab {
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: rgba(246, 239, 230, 0.06);
  color: #b8b1a7;
  font-size: 24rpx;
}

.tab-active {
  background: linear-gradient(135deg, rgba(214, 176, 116, 0.24), rgba(214, 176, 116, 0.08));
  color: #f6efe6;
  border: 1rpx solid rgba(214, 176, 116, 0.28);
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #f6efe6;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d8579;
}

.bottom-bar-spacer {
  height: calc(112rpx + env(safe-area-inset-bottom));
}
