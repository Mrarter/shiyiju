.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.tab-safe {
  height: env(safe-area-inset-bottom);
}

.tab-bar {
  height: 100rpx;
  display: flex;
  align-items: center;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  background: #fff;
}

.tab-item-active {
  color: #000;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-item:nth-child(2) .tab-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.tab-text {
  font-size: 22rpx;
  margin-top: 2rpx;
}
