/* 自定义 TabBar - 支持亮色/暗色主题 */

.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  background: var(--tabbar-bg);
  border-top: 1rpx solid var(--tabbar-border);
  transition: background-color 0.3s ease, border-color 0.3s ease;
}

.tab-safe {
  height: env(safe-area-inset-bottom);
}

.tab-bar {
  height: 100rpx;
  display: flex;
  align-items: center;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--tabbar-text);
  background: transparent;
  position: relative;
  transition: color 0.3s ease;
}

.tab-item-active {
  color: var(--tabbar-text-active);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-item:nth-child(2) .tab-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.tab-text {
  font-size: 22rpx;
  margin-top: 2rpx;
}

/* 购物车徽章 */
.cart-badge {
  position: absolute;
  top: 8rpx;
  right: 50%;
  transform: translateX(30rpx);
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: var(--color-error);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
