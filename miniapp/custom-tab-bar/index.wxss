.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  background: rgba(11, 10, 8, 0.96);
  backdrop-filter: blur(14px);
  border-top: 1rpx solid rgba(214, 176, 116, 0.08);
}

.tab-safe {
  height: env(safe-area-inset-bottom);
}

.tab-bar {
  height: 112rpx;
  display: flex;
  align-items: center;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8d8579;
}

.tab-item-active {
  color: #d6b074;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(214, 176, 116, 0.08);
  font-size: 20rpx;
  margin-bottom: 8rpx;
}

.tab-item-active .tab-icon {
  background: linear-gradient(135deg, rgba(214, 176, 116, 0.22), rgba(214, 176, 116, 0.08));
}

.tab-text {
  font-size: 20rpx;
}
