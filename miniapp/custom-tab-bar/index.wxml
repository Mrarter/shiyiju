<view class="tab-shell">
  <view class="tab-safe"></view>
  <view class="tab-bar">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-item-active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-icon">{{item.icon}}</view>
      <view class="tab-text">{{item.text}}</view>
    </view>
  </view>
</view>
