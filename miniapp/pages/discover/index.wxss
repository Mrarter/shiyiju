.discover-page {
  min-height: 100vh;
  background: #191919;
  color: #f3efe7;
}

.page-body {
  padding: 18rpx 20rpx 36rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  align-items: center;
  padding: 8rpx 0 14rpx;
}

.top-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #f5f1ea;
}

.brand-word {
  text-align: center;
  font-size: 64rpx;
  line-height: 1;
  font-weight: 300;
  letter-spacing: 2rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  padding: 10rpx 0 18rpx;
}

.filter-chip {
  min-width: 94rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  color: #e7e2da;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-sizing: border-box;
}

.filter-chip-active {
  background: #ece7df;
  color: #1b1b1b;
}

.loading-card {
  padding: 26rpx 24rpx;
  background: #232323;
  color: #d3ccc3;
}

.retry-btn {
  margin-top: 20rpx;
  width: 148rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #d5b06a;
  color: #16110f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.waterfall {
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.feed-card {
  width: 100%;
}

.art-image {
  width: 100%;
  overflow: hidden;
  background: #2b2b2b;
}

.art-image-landscape {
  height: 288rpx;
}

.art-image-portrait {
  height: 520rpx;
}

.art-image-square {
  height: 400rpx;
}

.card-image,
.placeholder-art {
  width: 100%;
  height: 100%;
  display: block;
}

.placeholder-art {
  position: relative;
  overflow: hidden;
}

.art-glow {
  position: absolute;
  left: 48rpx;
  top: 38rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  opacity: 0.9;
}

.art-mountain {
  position: absolute;
  bottom: 0;
  width: 210rpx;
  height: 150rpx;
  opacity: 0.9;
  clip-path: polygon(0 100%, 48% 18%, 100% 100%);
}

.art-mountain.left {
  left: 120rpx;
}

.art-mountain.center {
  left: 230rpx;
  height: 110rpx;
}

.art-mountain.right {
  right: -20rpx;
}

.slot-row {
  display: flex;
  gap: 0;
  margin-top: 16rpx;
}

.slot-tag {
  min-width: 74rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.65);
  background: #ede7df;
  color: #1c1c1c;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  box-sizing: border-box;
}

.slot-tag.dark {
  background: transparent;
  color: #efebe3;
  border-left: none;
}

.feed-title {
  margin-top: 22rpx;
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 700;
  word-break: break-all;
}

.feed-meta {
  margin-top: 12rpx;
  color: #c8c1b7;
  font-size: 24rpx;
  line-height: 1.5;
}

.feed-price-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
}

.feed-price {
  color: #f33616;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 700;
}

.follow-btn {
  min-width: 110rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.32);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  box-sizing: border-box;
}

.followed {
  color: #d9d4cb;
  border-color: rgba(255, 255, 255, 0.26);
}

.discount-chip {
  display: inline-flex;
  margin-top: 16rpx;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #a31811;
  color: #ffe3db;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.deadline-row {
  margin-top: 18rpx;
  color: #ff7b09;
  font-size: 26rpx;
  line-height: 1.4;
}

.feed-status {
  padding: 34rpx 0 18rpx;
  text-align: center;
  color: rgba(243, 239, 231, 0.58);
  font-size: 24rpx;
  letter-spacing: 1rpx;
}
