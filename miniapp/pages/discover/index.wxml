<view class="discover-page">
  <view class="safe-top"></view>

  <view class="page-body">
    <view class="topbar">
      <view class="top-icon" bindtap="handleSearchTap">⌕</view>
      <view class="brand-word">拾艺局</view>
      <view class="top-icon" bindtap="handleCreateTap">＋</view>
    </view>

    <view class="filter-row">
      <view
        class="filter-chip {{activeFilter === item ? 'filter-chip-active' : ''}}"
        wx:for="{{filters}}"
        wx:key="*this"
        data-filter="{{item}}"
        bindtap="handleTabTap"
      >
        {{item}}
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-card">发现页加载中...</view>

    <view wx:elif="{{error}}">
      <view class="loading-card">{{error}}</view>
      <view class="retry-btn" bindtap="handleRetry">重试</view>
    </view>

    <view wx:else>
      <view wx:if="{{feedItems.length}}" class="waterfall">
        <view class="waterfall-column">
          <view
            class="feed-card"
            wx:for="{{leftColumn}}"
            wx:key="artworkId"
          >
            <view class="art-image art-image-{{item.visual.ratio}}" bindtap="goArtworkDetail" data-artwork-id="{{item.artworkId}}">
              <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="card-image"></image>
              <view wx:else class="placeholder-art" style="background: {{item.visual.background}};">
                <view class="art-glow" style="background: {{item.visual.glow}};"></view>
                <view class="art-mountain left" style="background: {{item.visual.mountain}};"></view>
                <view class="art-mountain center" style="background: {{item.visual.mountain}};"></view>
                <view class="art-mountain right" style="background: {{item.visual.mountain}};"></view>
              </view>
            </view>
            <view class="slot-row">
              <view class="slot-tag">{{item.slotPrimary}}</view>
              <view class="slot-tag dark">{{item.slotSecondary}}</view>
            </view>
            <view class="feed-title">{{item.title}}</view>
            <view class="feed-meta">{{item.metaText}}</view>
            <view class="feed-price-row">
              <view class="feed-price">{{item.priceText}}</view>
              <view class="follow-btn {{item.followed ? 'followed' : ''}}" bindtap="handleFollowTap" data-artwork-id="{{item.artworkId}}">
                {{item.followed ? '已关注' : '关注'}}
              </view>
            </view>
            <view wx:if="{{item.discountText}}" class="discount-chip">{{item.discountText}}</view>
            <view class="deadline-row">🔨 {{item.deadlineText}}</view>
          </view>
        </view>

        <view class="waterfall-column">
          <view
            class="feed-card"
            wx:for="{{rightColumn}}"
            wx:key="artworkId"
          >
            <view class="art-image art-image-{{item.visual.ratio}}" bindtap="goArtworkDetail" data-artwork-id="{{item.artworkId}}">
              <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="card-image"></image>
              <view wx:else class="placeholder-art" style="background: {{item.visual.background}};">
                <view class="art-glow" style="background: {{item.visual.glow}};"></view>
                <view class="art-mountain left" style="background: {{item.visual.mountain}};"></view>
                <view class="art-mountain center" style="background: {{item.visual.mountain}};"></view>
                <view class="art-mountain right" style="background: {{item.visual.mountain}};"></view>
              </view>
            </view>
            <view class="slot-row">
              <view class="slot-tag">{{item.slotPrimary}}</view>
              <view class="slot-tag dark">{{item.slotSecondary}}</view>
            </view>
            <view class="feed-title">{{item.title}}</view>
            <view class="feed-meta">{{item.metaText}}</view>
            <view class="feed-price-row">
              <view class="feed-price">{{item.priceText}}</view>
              <view class="follow-btn {{item.followed ? 'followed' : ''}}" bindtap="handleFollowTap" data-artwork-id="{{item.artworkId}}">
                {{item.followed ? '已关注' : '关注'}}
              </view>
            </view>
            <view wx:if="{{item.discountText}}" class="discount-chip">{{item.discountText}}</view>
            <view class="deadline-row">🔨 {{item.deadlineText}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{feedItems.length}}" class="feed-status">
        <view wx:if="{{loadingMore}}">正在加载更多作品...</view>
        <view wx:elif="{{hasMore}}">继续上滑，加载更多作品</view>
        <view wx:else>已经到底了</view>
      </view>

      <view wx:else class="loading-card">当前筛选下还没有作品</view>
    </view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
