<view class="cart-page">
  <view class="safe-top"></view>

  <view class="page-header">
    <view class="page-title">购物车</view>
    <view class="page-subtitle">选中的作品将会为你保留</view>
  </view>

  <view class="page-body" wx:if="{{!loading && !error}}">
    <view class="cart-list" wx:if="{{cartItems.length > 0}}">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
        <view class="item-check" bindtap="toggleItem" data-id="{{item.id}}">
          <view class="check-icon {{item.selected ? 'checked' : ''}}">{{item.selected ? '✓' : ''}}</view>
        </view>
        <view class="item-image-wrap">
          <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="item-image"></image>
          <view wx:else class="item-image fallback-art" style="background: {{item.coverStyle.background}};">
            <view class="art-glow small" style="background: {{item.coverStyle.glow}};"></view>
            <view class="art-mountain left small" style="background: {{item.coverStyle.mountain}};"></view>
            <view class="art-mountain center small" style="background: {{item.coverStyle.mountain}};"></view>
            <view class="art-mountain right small" style="background: {{item.coverStyle.mountain}};"></view>
          </view>
        </view>
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-meta">{{item.artistName}} · {{item.categoryText}}</view>
          <view class="item-bottom">
            <view class="item-price">{{item.priceText}}</view>
            <view class="item-actions">
              <view class="action-btn minus" bindtap="decreaseCount" data-id="{{item.id}}">−</view>
              <view class="item-count">{{item.count}}</view>
              <view class="action-btn plus" bindtap="increaseCount" data-id="{{item.id}}">+</view>
            </view>
          </view>
        </view>
        <view class="item-delete" bindtap="removeItem" data-id="{{item.id}}">×</view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <view class="empty-icon">🛒</view>
      <view class="empty-title">购物车是空的</view>
      <view class="empty-desc">去首页发现喜欢的作品吧</view>
      <view class="empty-action" bindtap="goHome">去首页</view>
    </view>

    <view class="cart-summary" wx:if="{{cartItems.length > 0}}">
      <view class="summary-left">
        <view class="select-all" bindtap="toggleSelectAll">
          <view class="check-icon {{allSelected ? 'checked' : ''}}">{{allSelected ? '✓' : ''}}</view>
          <view class="select-text">全选</view>
        </view>
        <view class="total-info">
          <view class="total-label">合计</view>
          <view class="total-price">{{totalPrice}}</view>
        </view>
      </view>
      <view class="checkout-btn" bindtap="handleCheckout">
        结算 ({{selectedCount}})
      </view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{loading}}">
    <view class="loading-state">购物车加载中...</view>
  </view>

  <view class="page-body" wx:elif="{{error}}">
    <view class="error-state">{{error}}</view>
    <view class="retry-btn" bindtap="loadCart">重试</view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
