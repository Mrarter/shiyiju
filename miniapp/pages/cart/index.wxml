<view class="cart-page">
  <!-- 顶部导航 -->
  <view class="cart-header">
    <view class="header-title">购物车</view>
    <view class="header-count" wx:if="{{cartItems.length > 0}}">{{cartItems.length}} 件商品</view>
    <view class="edit-btn" bindtap="toggleEditMode" wx:if="{{cartItems.length > 0}}">
      {{isEditMode ? '完成' : '编辑'}}
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="cart-body {{recommendProducts.length > 0 ? 'has-recommend' : ''}}" wx:if="{{!loading && !error}}">
    <view class="cart-list" wx:if="{{cartItems.length > 0}}">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <!-- 选择框 -->
        <view class="item-check" bindtap="toggleItem" data-id="{{item.id}}">
          <view class="check-circle {{item.selected ? 'checked' : ''}}">
            <view class="check-inner" wx:if="{{item.selected}}"></view>
          </view>
        </view>

        <!-- 商品图片 -->
        <view class="item-image-wrap">
          <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="item-image"></image>
          <view wx:else class="item-image fallback">
            <view class="fallback-icon">🎨</view>
          </view>
        </view>

        <!-- 商品信息 -->
        <view class="item-content">
          <view class="item-title">{{item.title}}</view>
          <view class="item-artist">{{item.artistName}}</view>
          <view class="item-spec">
            <text wx:if="{{item.category === 'PAINTING'}}">油画</text>
            <text wx:elif="{{item.category === 'PRINT'}}">版画</text>
            <text wx:elif="{{item.category === 'INK'}}">水墨</text>
            <text wx:elif="{{item.category === 'SCULPTURE'}}">雕塑</text>
            <text wx:else>综合</text>
            /{{item.widthCm}}cm×{{item.heightCm}}cm/{{item.creationYear}}年
          </view>
          <view class="item-bottom">
            <view class="item-price">¥{{item.price}}</view>
            <view class="item-stock" wx:if="{{item.stock > 0}}">剩余 {{item.stock}}</view>
            <view class="item-stock sold-out" wx:else>已售罄</view>
          </view>

          <!-- 数量选择器 -->
          <view class="quantity-wrap">
            <view class="qty-btn {{item.quantity <= 1 ? 'disabled' : ''}}" catchtap="decreaseCount" data-id="{{item.id}}">−</view>
            <view class="qty-value">{{item.quantity}}</view>
            <view class="qty-btn" catchtap="increaseCount" data-id="{{item.id}}">+</view>
          </view>
        </view>

        <!-- 删除按钮（编辑模式下显示） -->
        <view class="item-delete {{isEditMode ? 'show' : ''}}" catchtap="removeItem" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>

    <!-- 推荐作品 -->
    <view class="recommend-section" wx:if="{{recommendProducts.length > 0}}">
      <view class="recommend-header">
        <view class="recommend-title">为你推荐</view>
        <view class="recommend-more" bindtap="goHome">查看更多 ›</view>
      </view>
      <scroll-view class="recommend-scroll" scroll-x enable-flex>
        <view class="recommend-list">
          <view class="recommend-item" wx:for="{{recommendProducts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <view class="recommend-image-wrap">
              <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="recommend-image"></image>
              <view wx:else class="recommend-image fallback">
                <view class="fallback-icon">🎨</view>
              </view>
              <view class="recommend-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            </view>
            <view class="recommend-info">
              <view class="recommend-title">{{item.title}}</view>
              <view class="recommend-artist">{{item.artistName}}</view>
              <view class="recommend-price">¥{{item.price}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 空购物车 -->
    <view class="empty-state" wx:else>
      <view class="empty-icon">🛒</view>
      <view class="empty-title">购物车是空的</view>
      <view class="empty-desc">去发现更多喜欢的作品吧</view>
      <view class="empty-action" bindtap="goHome">去逛逛</view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:elif="{{loading}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <view class="error-text">{{error}}</view>
    <view class="retry-btn" bindtap="loadCart">重新加载</view>
  </view>

  <!-- 底部结算栏 -->
  <view class="cart-footer {{cartItems.length > 0 ? 'show' : ''}}">
    <view class="footer-left">
      <view class="select-all" bindtap="toggleSelectAll">
        <view class="check-circle {{allSelected ? 'checked' : ''}}">
          <view class="check-inner" wx:if="{{allSelected}}"></view>
        </view>
        <view class="select-text">全选</view>
      </view>
      <view class="total-section">
        <view class="total-label">合计</view>
        <view class="total-price">¥{{totalPrice}}</view>
      </view>
    </view>

    <view class="footer-right">
      <view class="checkout-btn {{selectedCount > 0 ? 'active' : 'disabled'}}" bindtap="handleCheckout">
        结算{{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer {{cartItems.length > 0 ? 'show' : ''}}"></view>
</view>
