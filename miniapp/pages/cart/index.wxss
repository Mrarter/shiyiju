.cart-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #160d0a 0%, #0f0907 100%);
  color: #f6eee8;
}

.page-header {
  padding: 36rpx 26rpx 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #dcc2a1;
}

.page-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8d8579;
}

.page-body {
  padding: 0 26rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #1b1310;
  border: 1rpx solid rgba(77, 53, 42, 0.85);
  border-radius: 24rpx;
}

.item-check {
  padding: 10rpx;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #5a4a3a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #d6b074;
}

.check-icon.checked {
  background: #d6b074;
  border-color: #d6b074;
  color: #0f0907;
}

.item-image-wrap {
  margin-left: 16rpx;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8d8579;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.item-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #d8b06a;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: #2a1d17;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #dcc2a1;
}

.item-count {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.item-delete {
  margin-left: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #2a1d17;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #8d8579;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8d8579;
}

.empty-action {
  margin-top: 40rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #d5b06a, #a67c33);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #120f0d;
}

.cart-summary {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 26rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #1b1310;
  border-top: 1rpx solid rgba(77, 53, 42, 0.85);
}

.summary-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-text {
  font-size: 26rpx;
  color: #8d8579;
}

.total-info {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #8d8579;
}

.total-price {
  font-size: 38rpx;
  font-weight: 700;
  color: #d8b06a;
}

.checkout-btn {
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #d5b06a, #a67c33);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #120f0d;
}

.loading-state,
.error-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #8d8579;
}

.retry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 20rpx 40rpx;
  background: #2a1d17;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #dcc2a1;
}

.fallback-art {
  position: relative;
  overflow: hidden;
}

.art-glow.small {
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  opacity: 0.95;
}

.art-mountain.small {
  position: absolute;
  bottom: 0;
  width: 100rpx;
  height: 60rpx;
  opacity: 0.86;
  clip-path: polygon(0 100%, 48% 18%, 100% 100%);
}

.art-mountain.left.small {
  left: 40rpx;
}

.art-mountain.center.small {
  left: 90rpx;
  height: 45rpx;
}

.art-mountain.right.small {
  right: -5rpx;
}

.bottom-bar-spacer {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
