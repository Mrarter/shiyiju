.cart-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部导航 */
.cart-header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-count {
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.edit-btn {
  position: absolute;
  right: 30rpx;
  font-size: 28rpx;
  color: #ff4d4f;
}

/* 购物车列表 */
.cart-body {
  padding: 20rpx 24rpx;
  padding-bottom: 180rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cart-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 选择框 */
.item-check {
  padding: 40rpx 16rpx 0 0;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.check-circle.checked {
  border-color: #ff4d4f;
  background: #ff4d4f;
}

.check-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #fff;
}

/* 商品图片 */
.item-image-wrap {
  flex-shrink: 0;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f8f8f8;
}

.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback-icon {
  font-size: 60rpx;
}

/* 商品内容 */
.item-content {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-artist {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.item-spec {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b8b8b8;
}

.item-bottom {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 16rpx;
}

.item-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.item-stock {
  font-size: 22rpx;
  color: #999;
}

.item-stock.sold-out {
  color: #ff4d4f;
}

/* 数量选择器 */
.quantity-wrap {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  width: fit-content;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.qty-btn.disabled {
  color: #ddd;
}

.qty-value {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 删除按钮 */
.item-delete {
  position: absolute;
  right: 0;
  top: 0;
  width: 100rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff4d4f;
  border-radius: 0 16rpx 16rpx 0;
  opacity: 0;
  transform: translateX(100rpx);
  transition: all 0.3s;
}

.item-delete.show {
  opacity: 1;
  transform: translateX(0);
}

.item-delete text {
  font-size: 24rpx;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 140rpx;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-action {
  margin-top: 48rpx;
  padding: 24rpx 64rpx;
  background: #ff4d4f;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #ff4d4f;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 20rpx 48rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.cart-footer.show {
  transform: translateY(0);
}

.footer-left {
  display: flex;
  align-items: center;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-text {
  font-size: 26rpx;
  color: #666;
}

.total-section {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #999;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.footer-right {
  display: flex;
  align-items: center;
}

.checkout-btn {
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.checkout-btn.active {
  background: #ff4d4f;
  color: #fff;
}

.checkout-btn.disabled {
  background: #ddd;
  color: #999;
}

/* 底部占位 */
.bottom-spacer {
  height: 0;
  transition: height 0.3s;
}

.bottom-spacer.show {
  height: 140rpx;
}

/* 推荐作品区域 */
.recommend-section {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.recommend-more {
  font-size: 24rpx;
  color: #999;
}

.recommend-scroll {
  white-space: nowrap;
}

.recommend-list {
  display: inline-flex;
  gap: 20rpx;
}

.recommend-item {
  width: 220rpx;
  flex-shrink: 0;
}

.recommend-image-wrap {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8f8f8;
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: #ff4d4f;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
}

.recommend-info {
  margin-top: 12rpx;
}

.recommend-info .recommend-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-artist {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.recommend-price {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ff4d4f;
}

/* 购物车有推荐时的内边距 */
.cart-body.has-recommend {
  padding-bottom: 320rpx;
}
