.nav-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #000;
  font-weight: 300;
}

.hold-stat {
  padding: 24rpx;
}

.hold-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hold-card {
  padding: 18rpx;
}

.hold-cover {
  height: 240rpx;
}
