<view class="app-shell">
  <view class="safe-top"></view>
  <view class="page-body">
    <view class="page-title">我的藏品</view>
    <view class="page-subtitle">查看你已收藏与持有的作品。</view>

    <view class="tabs section">
      <view class="tab {{currentTab === index ? 'tab-active' : ''}}" wx:for="{{tabs}}" wx:key="*this" data-index="{{index}}" bindtap="handleTabTap">{{item}}</view>
    </view>

    <view class="section" wx:if="{{loading}}">
      <view class="surface-card page-subtitle">藏品页加载中...</view>
    </view>

    <view class="section" wx:elif="{{error}}">
      <view class="surface-card page-subtitle">{{error}}</view>
      <view class="gold-button" bindtap="handleRetry">重试</view>
    </view>

    <view class="section" wx:else>
      <view class="surface-card page-subtitle" wx:if="{{user}}">{{user.nickname || '当前用户'}} 暂无可展示的藏品记录，后续会继续补齐订单与藏品联动。</view>
      <view class="surface-card page-subtitle" wx:else>当前还未获取到用户藏品数据，后续会继续补齐登录与藏品联动。</view>
    </view>
  </view>
  <view class="bottom-bar-spacer"></view>
</view>
