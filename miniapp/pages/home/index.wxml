<view class="app-shell">
  <view class="safe-top"></view>
  <view class="page-body" wx:if="{{!loading && !error}}">
    <view class="section">
      <view class="surface-card hero-card">
        <view class="eyebrow">拾艺局</view>
        <view class="hero-title">艺术品流通与收藏</view>
        <view class="page-subtitle">发现艺术家与作品，完成收藏与流通。</view>
      </view>
    </view>

    <view class="section" wx:if="{{emptyState}}">
      <view class="surface-card page-subtitle">当前还没有足够的首页推荐数据，正在持续补充。</view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">热门藏品</view>
      </view>
      <view class="menu-list">
        <view class="surface-card menu-item" wx:for="{{hotWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view>
            <view class="menu-title">{{item.title}}</view>
            <view class="page-subtitle">{{item.subtitle}}</view>
          </view>
          <view>
            <view class="metric-value rise">{{item.priceText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">正在升值</view>
      </view>
      <view class="grid-two">
        <view class="surface-card value-card" wx:for="{{risingWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="value-title">{{item.title}}</view>
          <view class="page-subtitle">{{item.artistName}}</view>
          <view class="metric-value rise">{{item.priceText}}</view>
          <view class="page-subtitle">{{item.trendText}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐艺术家</view>
      </view>
      <view class="menu-list">
        <view class="surface-card menu-item" wx:for="{{recommendedArtists}}" wx:key="id" bindtap="goArtistProfile" data-artist-id="{{item.id}}">
          <view>
            <view class="menu-title">{{item.artistName}}</view>
            <view class="page-subtitle">{{item.levelName || '艺术家'}} · {{item.slogan || '持续上新中'}}</view>
          </view>
          <view class="menu-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{loading}}">
    <view class="section">
      <view class="surface-card page-subtitle">首页加载中...</view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{error}}">
    <view class="section">
      <view class="surface-card page-subtitle">{{error}}</view>
      <view class="gold-button" bindtap="handleRetry">重试</view>
    </view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
