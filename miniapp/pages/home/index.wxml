<view class="app-shell home-page">
  <view class="safe-top"></view>
  <view class="page-body" wx:if="{{!loading && !error}}">
    <view class="home-hero-block">
      <view class="eyebrow">拾艺局</view>
      <view class="hero-title">把喜欢的作品，真正收藏下来</view>
      <view class="page-subtitle">精选作品、在售艺术家与持续升值标的，一次看清。</view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">本期推荐</view>
      </view>
      <scroll-view scroll-x class="horizontal-scroll" enable-flex="true">
        <view class="horizontal-row">
          <view class="featured-mini-card" wx:for="{{featuredWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
            <image wx:if="{{item.coverUrl}}" class="featured-mini-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
            <view wx:else class="featured-fallback">{{item.coverFallback}}</view>
            <view class="featured-mini-body">
              <view class="tag">{{item.statusText}}</view>
              <view class="featured-mini-title">{{item.title}}</view>
              <view class="featured-mini-meta">{{item.artistName}}</view>
              <view class="featured-mini-price">{{item.priceText}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">热门藏品</view>
      </view>
      <view class="menu-list">
        <view class="surface-card compact-work-item" wx:for="{{hotWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view>
            <view class="menu-title">{{item.title}}</view>
            <view class="page-subtitle">{{item.artistName}} · {{item.statusText}}</view>
          </view>
          <view class="metric-value rise">{{item.priceText}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">正在升值</view>
      </view>
      <view class="trend-list">
        <view class="trend-card" wx:for="{{risingWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view>
            <view class="trend-title">{{item.title}}</view>
            <view class="trend-meta">{{item.artistName}}</view>
          </view>
          <view class="trend-right">
            <view class="trend-price">{{item.priceText}}</view>
            <view class="trend-status">{{item.statusText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐艺术家</view>
      </view>
      <view class="artist-list">
        <view class="artist-card" wx:for="{{recommendedArtists}}" wx:key="id" bindtap="goArtistProfile" data-artist-id="{{item.id}}">
          <view>
            <view class="artist-name">{{item.artistName}}</view>
            <view class="artist-level">{{item.levelName || '艺术家'}}</view>
            <view class="artist-slogan">{{item.slogan || '持续上新中'}}</view>
          </view>
          <view class="menu-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{loading}}">
    <view class="section">
      <view class="surface-card page-subtitle">首页加载中...</view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{error}}">
    <view class="section">
      <view class="surface-card page-subtitle">{{error}}</view>
      <view class="gold-button" bindtap="handleRetry">重试</view>
    </view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
