<view class="app-shell">
  <view class="safe-top"></view>
  <view class="page-body" wx:if="{{!loading && !error}}">
    <view class="section">
      <view class="surface-card home-brand-card">
        <view class="eyebrow">拾艺局</view>
        <view class="hero-title">艺术品流通与收藏</view>
        <view class="page-subtitle">发现值得收藏的作品，关注艺术家的持续成长。</view>
      </view>
    </view>

    <view class="section" wx:if="{{featuredWork}}">
      <view class="section-head">
        <view class="section-title">本期推荐</view>
      </view>
      <view class="surface-card featured-card" bindtap="goArtworkDetail" data-artwork-id="{{featuredWork.id}}">
        <image wx:if="{{featuredWork.coverUrl}}" class="featured-cover" src="{{featuredWork.coverUrl}}" mode="aspectFill"></image>
        <view class="featured-body">
          <view class="tag-row">
            <view class="tag">{{featuredWork.statusText}}</view>
          </view>
          <view class="hero-title">{{featuredWork.title}}</view>
          <view class="page-subtitle">{{featuredWork.artistName}}</view>
          <view class="metric-value rise">{{featuredWork.priceText}}</view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{emptyState}}">
      <view class="surface-card page-subtitle">当前还没有足够的首页推荐数据，正在持续补充。</view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">热门藏品</view>
      </view>
      <view class="menu-list">
        <view class="surface-card compact-work-item" wx:for="{{hotWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view>
            <view class="menu-title">{{item.title}}</view>
            <view class="page-subtitle">{{item.artistName}} · {{item.statusText}}</view>
          </view>
          <view class="metric-value rise">{{item.priceText}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">正在升值</view>
      </view>
      <view class="grid-two home-grid-two">
        <view class="surface-card trend-card" wx:for="{{risingWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="value-title">{{item.title}}</view>
          <view class="page-subtitle">{{item.artistName}}</view>
          <view class="metric-value rise">{{item.priceText}}</view>
          <view class="page-subtitle">{{item.statusText}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐艺术家</view>
      </view>
      <view class="menu-list">
        <view class="surface-card artist-row" wx:for="{{recommendedArtists}}" wx:key="id" bindtap="goArtistProfile" data-artist-id="{{item.id}}">
          <view>
            <view class="menu-title">{{item.artistName}}</view>
            <view class="page-subtitle">{{item.levelName || '艺术家'}}</view>
            <view class="page-subtitle">{{item.slogan || '持续上新中'}}</view>
          </view>
          <view class="menu-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{loading}}">
    <view class="section">
      <view class="surface-card page-subtitle">首页加载中...</view>
    </view>
  </view>

  <view class="page-body" wx:elif="{{error}}">
    <view class="section">
      <view class="surface-card page-subtitle">{{error}}</view>
      <view class="gold-button" bindtap="handleRetry">重试</view>
    </view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
