<view class="home-page theme-{{theme || 'dark'}}">
  <view class="safe-top"></view>

  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="nav-left">
      <text class="search-icon">🔍</text>
    </view>
    <view class="nav-brand">拾艺局</view>
    <view class="nav-right">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="home-wrap" wx:if="{{!loading && !error}}">
    <!-- Banner 轮播 -->
    <view class="banner-section" wx:if="{{bannerItems.length > 0}}">
      <swiper class="banner-swiper" indicator-dots="{{bannerItems.length > 1}}" autoplay="{{bannerItems.length > 1}}" interval="5000" duration="500" circular="true">
        <swiper-item wx:for="{{bannerItems}}" wx:key="id">
          <image 
            src="{{item.coverUrl}}" 
            mode="widthFix" 
            class="banner-image"
            bindtap="goArtworkDetail" 
            data-artwork-id="{{item.targetId}}"
            binderror="onBannerImageError"
            data-index="{{index}}"
          ></image>
        </swiper-item>
      </swiper>
    </view>

    <!-- 分类导航 -->
    <view class="quick-nav">
      <view class="quick-nav-item" bindtap="goQuickNav" data-type="hot">
        <view class="quick-nav-icon" style="background: linear-gradient(135deg, #ff6b6b, #ee5a5a);">
          <text>🔥</text>
        </view>
        <view class="quick-nav-text">热门藏品</view>
      </view>
      <view class="quick-nav-item" bindtap="goQuickNav" data-type="rising">
        <view class="quick-nav-icon" style="background: linear-gradient(135deg, #52c41a, #389e0d);">
          <text>📈</text>
        </view>
        <view class="quick-nav-text">正在升值</view>
      </view>
      <view class="quick-nav-item" bindtap="goQuickNav" data-type="artist">
        <view class="quick-nav-icon" style="background: linear-gradient(135deg, #722ed1, #531dab);">
          <text>🎨</text>
        </view>
        <view class="quick-nav-text">推荐艺术家</view>
      </view>
      <view class="quick-nav-item" bindtap="goQuickNav" data-type="notice">
        <view class="quick-nav-icon" style="background: linear-gradient(135deg, #faad14, #d48806);">
          <text>📢</text>
        </view>
        <view class="quick-nav-text">公告</view>
      </view>
    </view>

    <!-- 瀑布流作品列表 -->
    <view class="waterfall-section">
      <view class="waterfall-left">
        <view class="artwork-card" wx:for="{{leftColumn}}" wx:key="id">
          <view class="artwork-image-wrap" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
            <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="widthFix" class="artwork-image"></image>
            <view wx:else class="artwork-image fallback-art" style="background: {{item.coverStyle.background}}; height: {{item.height || 400}}rpx;">
              <view class="art-glow small" style="background: {{item.coverStyle.glow}};"></view>
            </view>
            <view class="artwork-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            <view class="favorite-btn {{item.isFavorited ? 'favorited' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
              {{item.isFavorited ? '❤️' : '🤍'}}
            </view>
          </view>
          <view class="artwork-info">
            <view class="artwork-title">{{item.title}}</view>
            <view class="artwork-spec">{{item.spec}}</view>
            <view class="artwork-price-row">
              <view class="artwork-price">{{item.priceText}}</view>
              <view class="artwork-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</view>
            </view>
            <view class="artwork-countdown" wx:if="{{item.countdown}}">
              <text class="countdown-icon">🔥</text>
              <text>{{item.countdown}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="waterfall-right">
        <view class="artwork-card" wx:for="{{rightColumn}}" wx:key="id">
          <view class="artwork-image-wrap" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
            <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="widthFix" class="artwork-image"></image>
            <view wx:else class="artwork-image fallback-art" style="background: {{item.coverStyle.background}}; height: {{item.height || 400}}rpx;">
              <view class="art-glow small" style="background: {{item.coverStyle.glow}};"></view>
            </view>
            <view class="artwork-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            <view class="favorite-btn {{item.isFavorited ? 'favorited' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
              {{item.isFavorited ? '❤️' : '🤍'}}
            </view>
          </view>
          <view class="artwork-info">
            <view class="artwork-title">{{item.title}}</view>
            <view class="artwork-spec">{{item.spec}}</view>
            <view class="artwork-price-row">
              <view class="artwork-price">{{item.priceText}}</view>
              <view class="artwork-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</view>
            </view>
            <view class="artwork-countdown" wx:if="{{item.countdown}}">
              <text class="countdown-icon">🔥</text>
              <text>{{item.countdown}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{leftColumn.length > 0 || rightColumn.length > 0}}">
      <view class="loading-more" wx:if="{{loadingMore}}">
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
      </view>
      <view class="no-more" wx:elif="{{!hasMore}}">
        <view class="no-more-line"></view>
        <view class="no-more-text">— 没有更多了 —</view>
        <view class="no-more-line"></view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{leftColumn.length === 0 && rightColumn.length === 0 && !loading && !error}}">
      <view class="empty-icon">🎨</view>
      <view class="empty-title">暂无内容</view>
      <view class="empty-desc">平台内容准备中，敬请期待</view>
    </view>
  </view>

  <view class="home-wrap" wx:elif="{{loading}}">
    <view class="loading-state">
      <view class="loading-anim">
        <view class="loading-bar"></view>
      </view>
      加载中...
    </view>
  </view>

  <view class="home-wrap" wx:elif="{{error}}">
    <view class="error-state">{{error}}</view>
    <view class="retry-btn" bindtap="handleRetry">重试</view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
