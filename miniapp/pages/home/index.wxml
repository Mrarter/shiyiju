<view class="home-page">
  <view class="safe-top"></view>

  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="nav-left">
      <text class="search-icon">🔍</text>
    </view>
    <view class="nav-brand">拾艺局</view>
    <view class="nav-right">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="home-wrap" wx:if="{{!loading && !error}}">
    <!-- Banner 轮播 -->
    <view class="banner-section" wx:if="{{bannerItems.length > 0}}">
      <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="5000" duration="500">
        <swiper-item wx:for="{{bannerItems}}" wx:key="id">
          <view class="banner-item" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
            <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="banner-image"></image>
            <view wx:else class="banner-image fallback-art" style="background: {{item.coverStyle.background}};">
              <view class="art-glow" style="background: {{item.coverStyle.glow}};"></view>
            </view>
            <view class="banner-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            <view class="banner-info">
              <view class="banner-title">{{item.title}}</view>
              <view class="banner-subtitle">{{item.subtitle}}</view>
              <view class="banner-date">{{item.date}}</view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 分类导航 -->
    <view class="category-section">
      <view class="category-item {{currentCategory === index ? 'active' : ''}}" 
            wx:for="{{categories}}" 
            wx:key="id" 
            data-index="{{index}}"
            bindtap="switchCategory">
        <view class="category-icon">{{item.icon}}</view>
        <view class="category-name">{{item.name}}</view>
      </view>
    </view>

    <!-- 瀑布流作品列表 -->
    <view class="waterfall-section">
      <view class="waterfall-left">
        <view class="artwork-card" wx:for="{{leftColumn}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="artwork-image-wrap">
            <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="widthFix" class="artwork-image"></image>
            <view wx:else class="artwork-image fallback-art" style="background: {{item.coverStyle.background}}; height: {{item.height || 400}}rpx;">
              <view class="art-glow small" style="background: {{item.coverStyle.glow}};"></view>
            </view>
            <view class="artwork-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          </view>
          <view class="artwork-info">
            <view class="artwork-title">{{item.title}}</view>
            <view class="artwork-spec">{{item.spec}}</view>
            <view class="artwork-price-row">
              <view class="artwork-price">{{item.priceText}}</view>
              <view class="artwork-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</view>
            </view>
            <view class="artwork-countdown" wx:if="{{item.countdown}}">
              <text class="countdown-icon">🔥</text>
              <text>{{item.countdown}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="waterfall-right">
        <view class="artwork-card" wx:for="{{rightColumn}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="artwork-image-wrap">
            <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="widthFix" class="artwork-image"></image>
            <view wx:else class="artwork-image fallback-art" style="background: {{item.coverStyle.background}}; height: {{item.height || 400}}rpx;">
              <view class="art-glow small" style="background: {{item.coverStyle.glow}};"></view>
            </view>
            <view class="artwork-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          </view>
          <view class="artwork-info">
            <view class="artwork-title">{{item.title}}</view>
            <view class="artwork-spec">{{item.spec}}</view>
            <view class="artwork-price-row">
              <view class="artwork-price">{{item.priceText}}</view>
              <view class="artwork-original" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</view>
            </view>
            <view class="artwork-countdown" wx:if="{{item.countdown}}">
              <text class="countdown-icon">🔥</text>
              <text>{{item.countdown}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!hasAnyContent}}">
      <view class="empty-icon">🎨</view>
      <view class="empty-title">暂无内容</view>
      <view class="empty-desc">平台内容准备中，敬请期待</view>
    </view>
  </view>

  <view class="home-wrap" wx:elif="{{loading}}">
    <view class="loading-state">加载中...</view>
  </view>

  <view class="home-wrap" wx:elif="{{error}}">
    <view class="error-state">{{error}}</view>
    <view class="retry-btn" bindtap="handleRetry">重试</view>
  </view>

  <view class="bottom-bar-spacer"></view>
</view>
