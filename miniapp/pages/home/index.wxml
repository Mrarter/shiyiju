<view class="app-shell">
  <view class="safe-top"></view>
  <view class="page-body">
    <view class="home-nav">
      <view>
        <view class="brand">拾艺局</view>
        <view class="brand-sub">新一代艺术品流通平台</view>
      </view>
      <view class="nav-actions">
        <view class="nav-btn">搜</view>
        <view class="nav-btn">讯</view>
      </view>
    </view>

    <view class="hero-card hero">
      <view class="tag-row">
        <view class="tag">首页成交页</view>
        <view class="tag tag-dark">可开发版</view>
      </view>
      <view class="hero-title">每一件艺术品<br/>都值得被收藏，也值得被传承</view>
      <view class="hero-desc">先看见价值，再建立信任，最后完成入藏转化。</view>
      <view class="hero-actions">
        <view class="gold-button">立即入藏</view>
        <view class="secondary-button">查看详情</view>
      </view>
    </view>

    <view class="section" wx:if="{{error}}">
      <view class="surface-card page-subtitle">{{error}}</view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">热门藏品</view>
        <view class="section-link">更多</view>
      </view>
      <view class="grid-two">
        <view class="work-card work" wx:for="{{hotWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="work-cover work-cover-lg">
            <view class="tag">{{item.badge}}</view>
          </view>
          <view class="work-title">{{item.title}}</view>
          <view class="work-artist">{{item.artist}}</view>
          <view class="work-footer">
            <view class="work-price">{{item.price}}</view>
            <view class="rise">{{item.rise}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">正在升值</view>
        <view class="section-link">算法推荐</view>
      </view>
      <view class="grid-two">
        <view class="surface-card value-card" wx:for="{{risingWorks}}" wx:key="id" bindtap="goArtworkDetail" data-artwork-id="{{item.id}}">
          <view class="value-title">{{item.title}}</view>
          <view class="metric-value rise">{{item.price}}</view>
          <view class="page-subtitle">{{item.stats}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐艺术家</view>
        <view class="section-link">查看全部</view>
      </view>
      <view class="artist-list">
        <view class="profile-card artist-card" wx:for="{{artists}}" wx:key="id" bindtap="goArtistProfile" data-artist-id="{{item.id}}">
          <view class="avatar"></view>
          <view class="artist-meta">
            <view class="artist-name-row">
              <view class="artist-name">{{item.name}}</view>
              <view class="tag">{{item.level}}</view>
            </view>
            <view class="page-subtitle">{{item.desc}}</view>
          </view>
          <view class="secondary-button follow-btn">关注</view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{loading}}">
      <view class="surface-card page-subtitle">数据加载中...</view>
    </view>
  </view>
  <view class="bottom-bar-spacer"></view>
</view>
