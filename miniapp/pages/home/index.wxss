.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #160d0a 0%, #0f0907 100%);
  color: #f6eee8;
}

.home-wrap {
  padding: 36rpx 26rpx 42rpx;
}

.home-header {
  padding: 6rpx 10rpx 24rpx;
}

.brand {
  font-size: 38rpx;
  color: #dcc2a1;
  font-weight: 600;
}

.subtitle {
  margin-top: 18rpx;
  font-size: 66rpx;
  line-height: 1.2;
  font-weight: 700;
}

.desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #b7a493;
}

.hero-card,
.summary-card,
.hot-card,
.rise-card,
.state-card,
.empty-state {
  background: #1b1310;
  border: 1rpx solid rgba(77, 53, 42, 0.85);
  border-radius: 30rpx;
  box-sizing: border-box;
}

.hero-card {
  overflow: hidden;
}

.hero-image-wrap {
  padding: 24rpx 24rpx 0;
}

.hero-image,
.hot-image,
.fallback-art {
  width: 100%;
  display: block;
  border-radius: 22rpx;
}

.hero-image,
.fallback-art {
  height: 360rpx;
}

.hero-body {
  padding: 22rpx 28rpx 28rpx;
}

.hero-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 110rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #2a1d17;
  color: #e7c899;
  font-size: 24rpx;
}

.hero-title {
  margin-top: 28rpx;
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 700;
}

.hero-meta,
.summary-desc,
.hot-meta,
.rise-meta,
.rise-status,
.empty-desc {
  font-size: 28rpx;
  color: #b7a493;
}

.hero-meta {
  margin-top: 14rpx;
}

.hero-bottom,
.module-head,
.rise-card,
.hero-actions,
.summary-grid {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-bottom {
  margin-top: 26rpx;
}

.hero-price,
.hot-price,
.rise-price {
  color: #d8b06a;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 700;
}

.hero-status {
  font-size: 26rpx;
  color: #b7a493;
  margin-top: 22rpx;
}

.summary-grid {
  gap: 18rpx;
  margin-top: 22rpx;
}

.summary-card {
  flex: 1;
  padding: 22rpx 24rpx;
  background: #241915;
}

.summary-title,
.module-title {
  font-size: 38rpx;
  font-weight: 700;
}

.summary-desc,
.module-count {
  margin-top: 10rpx;
}

.module {
  margin-top: 34rpx;
}

.module-head {
  margin-bottom: 18rpx;
  padding: 0 6rpx;
}

.module-count {
  font-size: 24rpx;
  color: #968575;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.hot-card {
  padding: 18rpx;
}

.hot-image,
.hot-image-wrap .fallback-art {
  height: 136rpx;
}

.hot-title,
.rise-title,
.empty-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.hot-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.hot-price {
  margin-top: 10rpx;
  font-size: 42rpx;
}

.rise-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.rise-card {
  padding: 22rpx 28rpx;
}

.rise-main {
  flex: 1;
  min-width: 0;
}

.rise-side {
  margin-left: 18rpx;
  text-align: right;
}

.rise-title,
.hot-title,
.hero-title,
.hot-meta,
.rise-meta {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rise-title {
  margin-top: 0;
}

.rise-meta,
.rise-status {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.fallback-art {
  position: relative;
  overflow: hidden;
}

.art-glow {
  position: absolute;
  left: 64rpx;
  top: 48rpx;
  width: 208rpx;
  height: 208rpx;
  border-radius: 50%;
  opacity: 0.95;
}

.art-glow.small {
  left: 30rpx;
  top: 20rpx;
  width: 104rpx;
  height: 104rpx;
}

.art-mountain {
  position: absolute;
  bottom: 0;
  width: 320rpx;
  height: 220rpx;
  opacity: 0.86;
  clip-path: polygon(0 100%, 48% 18%, 100% 100%);
}

.art-mountain.left {
  left: 300rpx;
}

.art-mountain.center {
  left: 520rpx;
  height: 160rpx;
}

.art-mountain.right {
  right: -20rpx;
}

.art-mountain.small {
  width: 120rpx;
  height: 76rpx;
}

.art-mountain.left.small {
  left: 110rpx;
}

.art-mountain.center.small {
  left: 190rpx;
  height: 58rpx;
}

.art-mountain.right.small {
  right: -10rpx;
}

.art-line {
  position: absolute;
  left: 64rpx;
  right: 120rpx;
  top: 170rpx;
  height: 8rpx;
  background: #ebcba7;
  transform: rotate(-13deg);
  transform-origin: center;
}

.art-line.small {
  left: 20rpx;
  right: 52rpx;
  top: 68rpx;
  height: 5rpx;
}

.state-card,
.empty-state {
  padding: 32rpx 28rpx;
}

.hero-actions {
  justify-content: flex-start;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero-action,
.retry-btn {
  height: 82rpx;
  padding: 0 28rpx;
  border-radius: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.06);
  color: #f6eee8;
}

.hero-action.primary,
.retry-btn {
  background: linear-gradient(135deg, #d5b06a, #a67c33);
  color: #120f0d;
}

.retry-btn {
  margin-top: 20rpx;
}
