.home-page {
  min-height: 100vh;
  background: #fff;
  color: #000;
}

.safe-top {
  height: env(safe-area-inset-top);
  background: #fff;
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left,
.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
}

.search-icon,
.add-icon {
  font-size: 40rpx;
  color: #000;
}

.add-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.nav-brand {
  font-size: 34rpx;
  font-weight: 700;
  color: #000;
}

.home-wrap {
  padding-bottom: 120rpx;
}

/* Banner */
.banner-section {
  margin-bottom: 24rpx;
}

.banner-swiper {
  height: 420rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 420rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.banner-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.banner-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.banner-date {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 分类导航 */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #000;
  font-weight: 600;
}

/* 瀑布流 */
.waterfall-section {
  display: flex;
  padding: 24rpx 16rpx;
  gap: 16rpx;
}

.waterfall-left,
.waterfall-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.artwork-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.artwork-image-wrap {
  position: relative;
  width: 100%;
}

.artwork-image {
  width: 100%;
  display: block;
}

.artwork-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.artwork-info {
  padding: 16rpx;
}

.artwork-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-spec {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 12rpx;
}

.artwork-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.artwork-original {
  font-size: 22rpx;
  color: #ccc;
  text-decoration: line-through;
}

.artwork-countdown {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #666;
}

.countdown-icon {
  margin-right: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.loading-state,
.error-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  font-size: 28rpx;
  color: #999;
}

.retry-btn {
  width: 160rpx;
  height: 72rpx;
  margin: 20rpx auto 0;
  border-radius: 36rpx;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

/* Fallback Art */
.fallback-art {
  position: relative;
  overflow: hidden;
}

.art-glow {
  position: absolute;
  left: 50%;
  top: 30%;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  opacity: 0.8;
  transform: translate(-50%, -50%);
}

.art-glow.small {
  width: 80rpx;
  height: 80rpx;
}

.bottom-bar-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* Swiper Indicators */
.banner-swiper .wx-swiper-dots {
  bottom: 20rpx;
}

.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.5);
}

.banner-swiper .wx-swiper-dot-active {
  background: #fff;
  width: 32rpx;
}
