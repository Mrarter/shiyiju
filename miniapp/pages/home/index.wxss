.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #160d0a 0%, #0f0907 100%);
  color: #f6eee8;
}

.nav-header {
  padding: 20rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-brand {
  font-size: 36rpx;
  font-weight: 700;
  color: #dcc2a1;
  white-space: nowrap;
}

.nav-search {
  flex: 1;
  height: 64rpx;
  padding: 0 24rpx;
  background: #1b1310;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-icon {
  font-size: 26rpx;
  opacity: 0.6;
}

.search-text {
  font-size: 26rpx;
  color: #8d8579;
}

.home-wrap {
  padding: 0 26rpx 40rpx;
}

.category-strip {
  display: flex;
  gap: 32rpx;
  padding: 10rpx 0 24rpx;
  overflow-x: auto;
}

.category-item {
  font-size: 28rpx;
  color: #8d8579;
  white-space: nowrap;
  padding-bottom: 8rpx;
  border-bottom: 4rpx solid transparent;
}

.category-item.active {
  color: #dcc2a1;
  border-bottom-color: #d6b074;
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
}

.section-more {
  font-size: 26rpx;
  color: #8d8579;
}

/* 精选推荐 */
.featured-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 16rpx;
}

.featured-card {
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.featured-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
}

.featured-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #d6b074;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #120f0d;
  font-weight: 600;
}

.featured-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-artist {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #b7a493;
}

.featured-price {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #d8b06a;
}

.featured-sub {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sub-card {
  flex: 1;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #1b1310;
}

.sub-image {
  width: 100%;
  height: 192rpx;
  display: block;
}

.sub-info {
  padding: 14rpx 16rpx;
}

.sub-title {
  font-size: 26rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub-price {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #d8b06a;
}

/* 热门作品 */
.hot-scroll {
  display: flex;
  gap: 18rpx;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.hot-card {
  flex: 0 0 240rpx;
  background: #1b1310;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(77, 53, 42, 0.85);
}

.hot-image-wrap {
  width: 100%;
  height: 200rpx;
}

.hot-image {
  width: 100%;
  height: 100%;
  display: block;
}

.hot-info {
  padding: 16rpx;
}

.hot-title {
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-artist {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8d8579;
}

.hot-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.hot-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #d8b06a;
}

.hot-cart {
  font-size: 32rpx;
}

/* 推荐艺术家 */
.artist-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.artist-card {
  text-align: center;
}

.artist-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin: 0 auto;
  display: block;
  border: 3rpx solid rgba(214, 176, 116, 0.3);
}

.artist-name {
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artist-level {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #d6b074;
}

/* 新品上市 */
.new-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.new-card {
  display: flex;
  gap: 20rpx;
  background: #1b1310;
  border-radius: 20rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(77, 53, 42, 0.85);
}

.new-image-wrap {
  flex-shrink: 0;
}

.new-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  display: block;
}

.new-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.new-title {
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.new-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8d8579;
}

.new-tags {
  margin-top: 10rpx;
}

.new-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(214, 176, 116, 0.15);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #d6b074;
}

.new-bottom {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.new-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #d8b06a;
}

.new-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #d5b06a, #a67c33);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #120f0d;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8d8579;
}

.loading-state,
.error-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  font-size: 28rpx;
  color: #8d8579;
}

.retry-btn {
  width: 160rpx;
  height: 72rpx;
  margin: 20rpx auto 0;
  border-radius: 20rpx;
  background: #2a1d17;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #dcc2a1;
}

/* Fallback Art Styles */
.fallback-art {
  position: relative;
  overflow: hidden;
}

.art-glow {
  position: absolute;
  left: 50%;
  top: 30%;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  opacity: 0.9;
  transform: translate(-50%, -50%);
}

.art-glow.small {
  width: 80rpx;
  height: 80rpx;
}

.art-mountain {
  position: absolute;
  bottom: 0;
  width: 200rpx;
  height: 100rpx;
  opacity: 0.8;
  clip-path: polygon(0 100%, 50% 20%, 100% 100%);
}

.art-mountain.left.small {
  left: 10rpx;
}

.art-mountain.center.small {
  left: 60rpx;
  height: 70rpx;
}

.bottom-bar-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
