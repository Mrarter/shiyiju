/* 首页样式 - 支持亮色/暗色主题 */

.home-page {
  min-height: 100vh;
  background: var(--page-bg);
  color: var(--text-primary);
  transition: background-color 0.3s ease, color 0.3s ease;
}

.safe-top {
  height: env(safe-area-inset-top);
  background: var(--navbar-bg);
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--navbar-bg);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--navbar-border);
  transition: background-color 0.3s ease, border-color 0.3s ease;
}

.nav-left,
.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
}

.search-icon,
.add-icon {
  font-size: 40rpx;
  color: var(--navbar-text);
}

.add-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.nav-brand {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--navbar-text);
}

.home-wrap {
  padding-bottom: 120rpx;
}

/* Banner */
.banner-section {
  margin-bottom: 24rpx;
}

.banner-swiper {
  width: 100%;
  height: 420rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  min-height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
}

.banner-image {
  width: 100%;
  height: 420rpx;
  display: block;
  background: var(--gradient-gold);
}

.banner-fallback {
  width: 100%;
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--gradient-gold);
}

.banner-fallback-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.banner-fallback-title {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.banner-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  background: var(--color-error);
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.banner-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: var(--gradient-overlay);
}

.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.banner-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.banner-date {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 分类导航 */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.category-item.active .category-name {
  color: var(--text-primary);
  font-weight: 600;
}

/* 快捷导航 */
.quick-nav {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 20rpx;
  background: var(--bg-card);
  border-bottom: 16rpx solid var(--bg-secondary);
  transition: background-color 0.3s ease;
}

.quick-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  box-shadow: var(--shadow-sm);
}

.quick-nav-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 瀑布流 */
.waterfall-section {
  display: flex;
  padding: 24rpx 16rpx;
  gap: 16rpx;
}

.waterfall-left,
.waterfall-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.artwork-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--border-secondary);
  transition: background-color 0.3s ease, border-color 0.3s ease;
}

.artwork-image-wrap {
  position: relative;
  width: 100%;
}

.artwork-image {
  width: 100%;
  display: block;
  background: var(--bg-secondary);
}

.artwork-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: var(--color-error);
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.favorite-btn {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 56rpx;
  height: 56rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: var(--shadow-sm);
}

.favorite-btn.favorited {
  background: var(--color-error-bg);
}

.artwork-info {
  padding: 16rpx;
}

.artwork-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-spec {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 12rpx;
}

.artwork-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-error);
}

.artwork-original {
  font-size: 22rpx;
  color: var(--text-disabled);
  text-decoration: line-through;
}

.artwork-countdown {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.countdown-icon {
  margin-right: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.loading-state,
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.loading-anim {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
}

.loading-bar {
  width: 100%;
  height: 100%;
  border: 4rpx solid var(--border-primary);
  border-top-color: var(--color-error);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.retry-btn {
  width: 160rpx;
  height: 72rpx;
  margin: 20rpx auto 0;
  border-radius: 36rpx;
  background: var(--gradient-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-inverse);
}

/* 加载更多 */
.load-more {
  padding: 40rpx 0;
}

.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.no-more-line {
  width: 100rpx;
  height: 1rpx;
  background: var(--border-primary);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--text-disabled);
}

/* Fallback Art */
.fallback-art {
  position: relative;
  overflow: hidden;
}

.art-glow {
  position: absolute;
  left: 50%;
  top: 30%;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  opacity: 0.8;
  transform: translate(-50%, -50%);
}

.art-glow.small {
  width: 80rpx;
  height: 80rpx;
}

.bottom-bar-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* Swiper Indicators */
.banner-swiper .wx-swiper-dots {
  bottom: 20rpx;
}

.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.5);
}

.banner-swiper .wx-swiper-dot-active {
  background: #fff;
  width: 32rpx;
}
