.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c0b 0%, #15100d 35%, #0b0908 100%);
  color: #fff;
}

.home-wrap {
  padding: 24rpx 24rpx 40rpx;
}

.hero-card,
.featured-card,
.hot-card,
.rise-card,
.artist-card,
.state-card,
.empty-state {
  background: rgba(23, 18, 16, 0.96);
  border: 1rpx solid rgba(201, 164, 92, 0.16);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.18);
}

.hero-card {
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(39, 28, 21, 0.98), rgba(20, 15, 12, 0.98));
}

.hero-top,
.module-head,
.artist-name-row,
.artist-left,
.hero-actions,
.rise-card,
.artist-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.brand {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.84);
}

.subtitle {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 700;
}

.hero-badge,
.card-tag,
.hot-tag,
.artist-rank,
.tag-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(214, 176, 116, 0.14);
  color: #f3d295;
  font-size: 20rpx;
}

.desc,
.module-desc,
.card-meta,
.hot-meta,
.rise-meta,
.rise-status,
.artist-level,
.artist-slogan,
.load-more-tip,
.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.7;
}

.desc {
  margin-top: 18rpx;
}

.hero-actions {
  margin-top: 24rpx;
  justify-content: flex-start;
  gap: 18rpx;
}

.hero-action,
.retry-btn {
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.06);
  color: #fff;
}

.hero-action.primary,
.retry-btn {
  background: linear-gradient(135deg, #d5b06a, #a67c33);
  color: #120f0d;
}

.module {
  margin-top: 32rpx;
}

.module-title {
  font-size: 34rpx;
  font-weight: 700;
}

.featured-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.featured-row {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 12rpx;
}

.featured-card {
  width: 430rpx;
  overflow: hidden;
}

.featured-cover-wrap {
  position: relative;
}

.featured-badge {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #120f0d;
  background: #f3d295;
}

.card-cover {
  width: 100%;
  height: 260rpx;
  display: block;
  background: #2a201a;
}

.fallback,
.artist-avatar,
.artist-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback {
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.75);
}

.card-body {
  padding: 22rpx;
}

.card-title,
.hot-title,
.rise-title,
.artist-name,
.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.card-price,
.hot-price,
.rise-price {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #f6d38a;
}

.hot-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.hot-card {
  padding: 22rpx;
  min-height: 220rpx;
}

.rise-list,
.artist-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rise-card,
.artist-card {
  padding: 24rpx;
}

.rise-main {
  flex: 1;
  min-width: 0;
}

.rise-side {
  text-align: right;
  margin-left: 20rpx;
}

.artist-left {
  flex: 1;
  min-width: 0;
  justify-content: flex-start;
  gap: 18rpx;
}

.artist-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(214, 176, 116, 0.16);
  overflow: hidden;
  flex-shrink: 0;
}

.artist-avatar-img {
  width: 100%;
  height: 100%;
}

.artist-avatar-fallback {
  width: 100%;
  height: 100%;
  font-size: 32rpx;
  font-weight: 700;
  color: #f3d295;
}

.artist-info {
  flex: 1;
  min-width: 0;
}

.artist-name-row {
  justify-content: flex-start;
  gap: 12rpx;
}

.artist-name,
.artist-slogan,
.card-title,
.hot-title,
.rise-title,
.card-meta,
.hot-meta {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  margin-left: 18rpx;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.45);
}

.load-more-tip {
  text-align: center;
}

.state-card,
.empty-state {
  padding: 28rpx;
}

.retry-btn {
  margin-top: 20rpx;
}
