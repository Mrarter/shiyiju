.home-page {
  background: #0f0c0b;
}

.home-hero-block {
  padding: 24rpx 0 8rpx;
}

.featured-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.featured-grid-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #171210;
  border: 1rpx solid rgba(201, 164, 92, 0.16);
}

.featured-grid-cover,
.featured-fallback {
  width: 100%;
  height: 200rpx;
  display: block;
  background: linear-gradient(180deg, #35281f, #1b1512);
}

.featured-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.75);
  font-size: 42rpx;
  font-weight: 700;
}

.featured-grid-body {
  padding: 20rpx;
}

.featured-grid-title,
.artist-name,
.trend-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.featured-grid-meta,
.artist-level,
.artist-slogan,
.trend-meta,
.trend-status {
  color: rgba(255,255,255,0.68);
  font-size: 22rpx;
  margin-top: 8rpx;
}

.featured-grid-price,
.trend-price {
  color: #f6d38a;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 14rpx;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.hot-grid-card {
  min-height: 200rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #171210;
  border: 1rpx solid rgba(201, 164, 92, 0.12);
}

.trend-list,
.artist-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trend-card,
.artist-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #171210;
  border: 1rpx solid rgba(201, 164, 92, 0.12);
}

.trend-right {
  text-align: right;
}
