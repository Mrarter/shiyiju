.home-page {
  background: #0f0c0b;
}

.home-hero-block {
  padding: 24rpx 0 8rpx;
}

.horizontal-scroll {
  white-space: nowrap;
}

.horizontal-row {
  display: flex;
  gap: 20rpx;
}

.featured-mini-card {
  width: 360rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #171210;
  border: 1rpx solid rgba(201, 164, 92, 0.16);
}

.featured-mini-cover,
.featured-fallback {
  width: 100%;
  height: 240rpx;
  display: block;
  background: linear-gradient(180deg, #35281f, #1b1512);
}

.featured-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.75);
  font-size: 48rpx;
  font-weight: 700;
}

.featured-mini-body {
  padding: 22rpx;
}

.featured-mini-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 14rpx;
}

.featured-mini-meta {
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.featured-mini-price {
  color: #f6d38a;
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

.compact-work-item {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-title,
.trend-title,
.artist-name {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.trend-list,
.artist-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trend-card,
.artist-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #171210;
  border: 1rpx solid rgba(201, 164, 92, 0.12);
}

.trend-right {
  text-align: right;
}

.hot-meta,
.hot-status,
.trend-meta,
.trend-status,
.artist-level,
.artist-slogan {
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.hot-price,
.trend-price {
  color: #f6d38a;
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 20rpx;
}
