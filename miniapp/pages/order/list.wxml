<view class="container">
  <!-- 固定返回按钮 -->
  <view class="fixed-back-btn" bindtap="goBack">
    <view class="back-arrow">‹</view>
  </view>

  <!-- 状态标签 -->
  <view class="tabs">
    <view 
      class="tab {{currentTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="switchTab"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="orderId">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="status {{item.orderStatus}}">{{formatStatus(item.orderStatus)}}</text>
      </view>

      <view class="artwork-item" bindtap="goOrderDetail" data-id="{{item.orderId}}">
        <image class="cover" src="{{item.coverUrl}}" mode="aspectFill" />
        <view class="info">
          <view class="title">{{item.itemTitle}}</view>
          <view class="price">¥{{item.payAmount}}</view>
        </view>
      </view>

      <view class="order-footer">
        <view class="time">{{item.createdAt}}</view>
        <view class="actions">
          <view wx:if="{{item.orderStatus === 'PENDING_PAYMENT'}}" class="btn small" bindtap="goPay" data-id="{{item.orderId}}">
            去支付
          </view>
          <view wx:if="{{item.orderStatus === 'PENDING_SHIPMENT'}}" class="btn small secondary">
            催发货
          </view>
          <view wx:if="{{item.orderStatus === 'SHIPPED'}}" class="btn small" bindtap="viewShipment" data-id="{{item.orderId}}">
            查看物流
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{orders.length === 0 && !loading}}">
      <image class="empty-icon" src="/images/empty-order.png" mode="aspectFit" />
      <text class="empty-text">暂无相关订单</text>
    </view>

    <!-- 加载更多 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
