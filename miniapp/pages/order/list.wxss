page {
  background: #f5f5f5;
}

/* 固定返回按钮 */
.fixed-back-btn {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: env(safe-area-inset-top);
}

.back-arrow {
  font-size: 56rpx;
  color: #333;
  font-weight: bold;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  padding-top: env(safe-area-inset-top);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #333;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.order-list {
  padding: 20rpx 30rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1px solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.status {
  font-size: 26rpx;
  color: #07c160;
}

.status.PENDING_PAYMENT {
  color: #ff9800;
}

.status.CANCELLED {
  color: #999;
}

.artwork-item {
  display: flex;
  padding: 24rpx 30rpx;
  align-items: center;
}

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.info {
  flex: 1;
  margin-left: 24rpx;
}

.title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1px solid #f0f0f0;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.btn.secondary {
  background: #fff;
  border: 1px solid #ddd;
  color: #666;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
