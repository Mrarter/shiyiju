.order-page {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 140rpx;
}

/* 顶部导航 */
.header-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-placeholder {
  width: 60rpx;
}

/* 地址卡片 */
.address-card {
  position: relative;
  background: linear-gradient(135deg, #323232 0%, #4a4a4a 100%);
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  overflow: hidden;
}

.add-address {
  display: flex;
  align-items: center;
  color: #fff;
}

.add-icon {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx dashed rgba(255,255,255,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.add-text {
  font-size: 28rpx;
}

.address-info {
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  margin-right: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.phone {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.address-detail {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.5;
}

/* 装饰条纹 */
.stripe-decoration {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 60rpx;
  display: flex;
  flex-direction: column;
}

.stripe {
  flex: 1;
}

.stripe.red {
  background: #e74c3c;
}

.stripe.blue {
  background: #3498db;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

/* 商品信息 */
.artwork-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.artwork-item.no-top-border {
  border-top: none;
  padding-top: 0;
}

.artwork-item + .artwork-item {
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.artwork-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.artwork-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.artwork-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-price-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.price {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.quantity {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

/* 买家留言 */
.remark-row {
  display: flex;
  align-items: center;
}

.remark-row .label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
}

.placeholder {
  color: #ccc;
}

/* 价格明细 */
.price-detail .price-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.price-detail .price-row:last-child {
  margin-bottom: 0;
}

.price-detail .gray {
  color: #ccc;
}

.total-row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  padding-top: 20rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.total-price {
  font-weight: 600;
  color: #ff6b00;
}

/* 支付方式 */
.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.payment-item:last-child {
  margin-bottom: 0;
}

.payment-item.selected {
  background: #f0fff4;
  border: 1rpx solid #07c160;
}

.payment-left {
  display: flex;
  align-items: center;
}

.payment-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

.payment-icon.alipay {
  background: #1677ff;
}

.payment-icon.wechat {
  background: #07c160;
}

.payment-info {
  flex: 1;
}

.payment-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.payment-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
}

.radio.checked {
  border-color: #07c160;
  background: #07c160;
  position: relative;
}

.radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
}

/* 匿名购买 */
.anonymous-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
}

.anonymous-switch {
  transform: scale(0.8);
}

/* 协议提示 */
.agreement-section {
  margin: 24rpx;
  padding: 20rpx;
}

.agreement-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #333;
}

.agreement-icon {
  width: 32rpx;
  height: 32rpx;
  background: #07c160;
  color: #fff;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.agreement-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.6;
  padding-left: 44rpx;
}

/* 底部结算栏 */
.bottom-spacer {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.total-wrap {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #999;
}

.total-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b00;
}

.submit-btn {
  background: linear-gradient(135deg, #323232 0%, #4a4a4a 100%);
  color: #fff;
  padding: 24rpx 64rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.submit-btn.disabled {
  background: #ccc;
}
