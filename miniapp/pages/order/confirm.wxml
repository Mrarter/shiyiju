<view class="order-page">
  <!-- 地址区域 -->
  <view class="address-card" bindtap="selectAddress">
    <view wx:if="{{!address}}" class="add-address">
      <view class="add-icon">+</view>
      <view class="add-text">添加收货地址</view>
    </view>
    <view wx:else class="address-info">
      <view class="user-info">
        <view class="avatar"></view>
        <view class="name">{{address.receiverName}}</view>
      </view>
      <view class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detailAddress}}</view>
    </view>
    <!-- 装饰条纹 -->
    <view class="stripe-decoration">
      <view class="stripe red"></view>
      <view class="stripe blue"></view>
      <view class="stripe red"></view>
      <view class="stripe blue"></view>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="section">
    <view class="artwork-item">
      <image class="artwork-img" src="{{artwork.coverUrl}}" mode="aspectFill" />
      <view class="artwork-info">
        <view class="artwork-title">{{artwork.title}} / {{artwork.category}} / {{artwork.widthCm}}×{{artwork.heightCm}}cm / {{artwork.creationYear}}</view>
        <view class="artwork-price-wrap">
          <view class="price">¥{{artwork.currentPrice}}.00</view>
          <view class="quantity">x1</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 买家留言 -->
  <view class="section remark-row">
    <text class="label">买家留言</text>
    <input class="remark-input" placeholder="选填，请输入" placeholder-class="placeholder" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <!-- 价格明细 -->
  <view class="section price-detail">
    <view class="price-row">
      <text>商品金额</text>
      <text>¥{{artwork.currentPrice}}.00</text>
    </view>
    <view class="price-row">
      <text>优惠券</text>
      <text class="gray">无可用 ></text>
    </view>
    <view class="price-row">
      <text>装裱费</text>
      <text>¥0.00</text>
    </view>
    <view class="price-row">
      <text>打包费</text>
      <text>¥0.00</text>
    </view>
    <view class="price-row">
      <text>邮费</text>
      <text>¥0.00</text>
    </view>
    <view class="total-row">
      <text>合计</text>
      <text class="total-price">¥{{artwork.currentPrice}}.00</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-item {{paymentMethod === 'alipay' ? 'selected' : ''}}" bindtap="selectPayment" data-method="alipay">
      <view class="payment-left">
        <view class="payment-icon alipay">支</view>
        <view class="payment-info">
          <view class="payment-name">支付宝</view>
          <view class="payment-desc">支付宝内余额支付可以解决支付宝内银行卡支付限额</view>
        </view>
      </view>
      <view class="radio {{paymentMethod === 'alipay' ? 'checked' : ''}}"></view>
    </view>
    <view class="payment-item {{paymentMethod === 'wechat' ? 'selected' : ''}}" bindtap="selectPayment" data-method="wechat">
      <view class="payment-left">
        <view class="payment-icon wechat">
          <view class="wechat-logo">✓</view>
        </view>
        <view class="payment-info">
          <view class="payment-name">微信支付</view>
          <view class="payment-desc">微信内零钱支付可以解决微信内银行卡支付限额</view>
        </view>
      </view>
      <view class="radio {{paymentMethod === 'wechat' ? 'checked' : ''}}"></view>
    </view>
  </view>

  <!-- 匿名购买 -->
  <view class="section anonymous-row">
    <text>匿名购买</text>
    <switch class="anonymous-switch" checked="{{isAnonymous}}" bindchange="toggleAnonymous" color="#07c160"/>
  </view>

  <!-- 协议提示 -->
  <view class="agreement-section">
    <view class="agreement-title">
      <view class="agreement-icon">✓</view>
      <text>同意艺术品不支持 7 天无理由退货</text>
    </view>
    <view class="agreement-desc">提示：鉴于艺术品具有特殊的性质，不支持 7 天无理由退货，您一旦勾选，提交订单付款后，即视为您同意。</view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar">
    <view class="total-wrap">
      <text class="total-label">合计（包邮）</text>
      <text class="total-amount">¥{{artwork.currentPrice}}.00</text>
    </view>
    <view class="submit-btn {{disabled ? 'disabled' : ''}}" bindtap="handlePay">
      <text wx:if="{{loading}}">提交中...</text>
      <text wx:else>提交订单</text>
    </view>
  </view>
</view>
