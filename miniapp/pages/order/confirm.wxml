<view class="container">
  <!-- 地址选择 -->
  <view class="section address-section" bindtap="selectAddress">
    <view wx:if="{{address}}">
      <view class="address-info">
        <view class="receiver">{{address.receiverName}}  {{address.receiverMobile}}</view>
        <view class="detail">{{address.province}}{{address.city}}{{address.district}}{{address.detailAddress}}</view>
      </view>
      <view class="arrow">›</view>
    </view>
    <view wx:else class="add-address">
      <text>添加收货地址</text>
      <view class="arrow">›</view>
    </view>
  </view>

  <!-- 作品信息 -->
  <view class="section artwork-section">
    <view class="artwork-card">
      <image class="cover" src="{{artwork.coverUrl}}" mode="aspectFill" />
      <view class="info">
        <view class="title">{{artwork.title}}</view>
        <view class="artist">{{artwork.artistName}}</view>
        <view class="spec">{{artwork.spec}}</view>
      </view>
      <view class="price">¥{{artwork.currentPrice}}</view>
    </view>
  </view>

  <!-- 订单备注 -->
  <view class="section remark-section">
    <view class="label">订单备注</view>
    <input class="remark-input" placeholder="选填，可备注特殊要求" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <!-- 支付方式 -->
  <view class="section payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-item selected">
      <image class="payment-icon" src="/images/wechat-pay.png" />
      <text>微信支付</text>
      <view class="check">✓</view>
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="section price-section">
    <view class="price-row">
      <text>作品金额</text>
      <text>¥{{artwork.currentPrice}}</text>
    </view>
    <view class="price-row">
      <text>运费</text>
      <text class="freight">免运费</text>
    </view>
    <view class="price-row total">
      <text>合计</text>
      <text class="total-price">¥{{artwork.currentPrice}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text class="label">实付款</text>
      <text class="amount">¥{{artwork.currentPrice}}</text>
    </view>
    <view class="pay-btn {{disabled ? 'disabled' : ''}}" bindtap="handlePay">
      <text wx:if="{{loading}}">支付中...</text>
      <text wx:else>确认支付</text>
    </view>
  </view>
</view>
