.nav-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #000;
  font-weight: 300;
}

.artist-header {
  padding: 28rpx;
  display: flex;
  gap: 20rpx;
}

.artist-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.artist-header-meta {
  flex: 1;
}

.stat-surface {
  padding: 22rpx;
}

.tiny-btn {
  min-width: 110rpx;
  height: 58rpx;
  font-size: 22rpx;
}
