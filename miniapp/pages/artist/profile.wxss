/* 固定返回按钮 */
.fixed-back-btn {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: env(safe-area-inset-top);
}

.back-arrow {
  font-size: 56rpx;
  color: #333;
  font-weight: bold;
}

.artist-header {
  padding: 28rpx;
  display: flex;
  gap: 20rpx;
}

.artist-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.artist-header-meta {
  flex: 1;
}

.stat-surface {
  padding: 22rpx;
}

.tiny-btn {
  min-width: 110rpx;
  height: 58rpx;
  font-size: 22rpx;
}
