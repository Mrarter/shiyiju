/* 固定返回按钮 */
.fixed-back-btn {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: env(safe-area-inset-top);
}

.back-arrow {
  font-size: 56rpx;
  color: #333;
  font-weight: bold;
}

.placeholder-card {
  padding: 28rpx;
}
