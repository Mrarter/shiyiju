.nav-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #000;
  font-weight: 300;
}

.step {
  padding: 22rpx;
  min-height: 138rpx;
}

.step-title {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.form-card {
  padding: 28rpx;
}

.form-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(214, 176, 116, 0.08);
  font-size: 26rpx;
}

.form-line:last-child {
  border-bottom: 0;
}

.method-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.method-item {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.method-radio {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d6b074;
}

.full-btn {
  width: 100%;
}
