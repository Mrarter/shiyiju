/* 固定返回按钮 */
.fixed-back-btn {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 999;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: env(safe-area-inset-top);
}

.back-arrow {
  font-size: 56rpx;
  color: #333;
  font-weight: bold;
}

.step {
  padding: 22rpx;
  min-height: 138rpx;
}

.step-title {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.form-card {
  padding: 28rpx;
}

.form-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(214, 176, 116, 0.08);
  font-size: 26rpx;
}

.form-line:last-child {
  border-bottom: 0;
}

.method-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.method-item {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.method-radio {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d6b074;
}

.full-btn {
  width: 100%;
}
